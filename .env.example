# =================================================================
# FORMEDICS ADAPTIVE CONCURRENCY: ENVIRONMENT TEMPLATE
# =================================================================

# --- WORDPRESS DATA LAYER ---
# The URL of the WordPress REST API (e.g., https://wp.formedics.com)
WP_API_URL=http://localhost:8080

# --- THE GOLDEN PATH (The Logic Engine's Truth) ---
# The baseline response time for a healthy WP-JSON search (ms)
GOLDEN_LATENCY_MS=250
# How much we tolerate drift before a hard squeeze (multiplier)
LATENCY_TOLERANCE=2.0

# --- CONCURRENCY BOUNDARIES ---
# The minimum requests allowed per instance (The Floor)
MIN_CONCURRENCY=2
# The maximum PHP-FPM workers assigned per instance (The Ceiling)
MAX_CONCURRENCY=20

# --- GCP INFRASTRUCTURE (The Actuator) ---
GCP_PROJECT_ID=formedics-production
GCP_REGION=us-central1
GCP_MIG_NAME=nextjs-clinical-app-group
# Step size for scaling (how many instances to add per trigger)
GCP_SCALE_STEP=1
# The maximum number of "New Fields" allowed
GCP_MAX_INSTANCES=10

# --- SIMULATION SETTINGS ---
# Set to 'true' to use MockActuator instead of hitting GCP APIs
USE_MOCK_ACTUATOR=true
# Set to 'DATA' to simulate a Read DB bottleneck vs 'COMPUTE'
BOTTLENECK_TYPE=COMPUTE